                          <option value="AB+">AB+</option><option value="AB-">AB-</option>
                          <option value="O+">O+</option><option value="O-">O-</option>
                        </select>
                      </div>
                      <div>
                        <label className="block text-xs font-bold text-slate-600 mb-1">الحساسية</label>
                        <textarea 
                          placeholder="أدخل أنواع الحساسية (أدوية، طعام، إلخ).."
                          value={emergencyProfile.allergies} 
                          onChange={e => setEmergencyProfile({...emergencyProfile, allergies: e.target.value})}
                          className="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 outline-none h-20 resize-none"
                        />
                      </div>
                      <div>
                        <label className="block text-xs font-bold text-slate-600 mb-1">الأمراض المزمنة</label>
                        <textarea 
                          placeholder="السكري، الضغط، إلخ.."
                          value={emergencyProfile.chronicDiseases} 
                          onChange={e => setEmergencyProfile({...emergencyProfile, chronicDiseases: e.target.value})}
                          className="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 outline-none h-20 resize-none"
                        />
                      </div>
                      <div>
                        <label className="block text-xs font-bold text-slate-600 mb-1">جهة اتصال للطوارئ</label>
                        <input 
                          type="text"
                          placeholder="الاسم ورقم الهاتف.."
                          value={emergencyProfile.emergencyContact} 
                          onChange={e => setEmergencyProfile({...emergencyProfile, emergencyContact: e.target.value})}
                          className="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 outline-none"
                        />
                      </div>
                      <div>
                        <label className="block text-xs font-bold text-slate-600 mb-1">معلومات إضافية / تعليمات</label>
                        <textarea 
                          placeholder="يرجى إعطاء الدواء X عند الإغماء، فصيلة الدم النادرة، إلخ.."
                          value={emergencyProfile.additionalInfo || ''} 
                          onChange={e => setEmergencyProfile({...emergencyProfile, additionalInfo: e.target.value})}
                          className="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-red-500 outline-none h-20 resize-none"
                        />
                      </div>
                      <button 
                        onClick={() => setIsEditingEmergency(false)}
                        className="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 rounded-xl transition-colors mt-2"
                      >
                        حفظ المعلومات
                      </button>
                    </div>
                  ) : (
                    <>
                      <div className="grid grid-cols-2 gap-4">
                        <div className="bg-red-50 rounded-xl p-4 border border-red-100 flex flex-col items-center justify-center text-center">
                          <Heart className="w-8 h-8 text-red-500 mb-2" />
                          <span className="text-[10px] uppercase font-bold tracking-widest text-red-400 mb-1">فصيلة الدم</span>
                          <span className="text-2xl font-black text-red-700 dir-ltr">{emergencyProfile.bloodType || '-'}</span>
                        </div>
                        <div className="bg-orange-50 rounded-xl p-4 border border-orange-100 flex flex-col items-center justify-center text-center">
                          <AlertCircle className="w-8 h-8 text-orange-500 mb-2" />
                          <span className="text-[10px] uppercase font-bold tracking-widest text-orange-400 mb-1">الحساسية</span>
                          <span className="text-sm font-bold text-orange-800 line-clamp-2">{emergencyProfile.allergies || 'لا يوجد'}</span>
                        </div>
                      </div>
                      <div className="bg-blue-50 rounded-xl p-4 border border-blue-100">
                         <div className="flex items-center gap-2 mb-2">
                           <Activity className="w-4 h-4 text-blue-500" />
                           <span className="text-xs font-bold text-blue-700">الأمراض المزمنة</span>
                         </div>
                         <p className="text-sm font-medium text-slate-700 whitespace-pre-wrap leading-relaxed">
                           {emergencyProfile.chronicDiseases || 'لا يوجد سجل أمراض مزمنة.'}
                         </p>
                      </div>
                      <div className="bg-slate-100 rounded-xl p-4 border border-slate-200">
                         <div className="flex items-center gap-2 mb-2">
                           <ShieldAlert className="w-4 h-4 text-slate-500" />
                           <span className="text-xs font-bold text-slate-700">جهة اتصال طوارئ</span>
                         </div>
                         <p className="text-sm font-bold text-slate-800">
                           {emergencyProfile.emergencyContact || 'غير متوفر'}
                         </p>
                      </div>
                      {(emergencyProfile.additionalInfo || isEditingEmergency) && (
                        <div className="bg-yellow-50 rounded-xl p-4 border border-yellow-200">
                           <div className="flex items-center gap-2 mb-2">
                             <Info className="w-4 h-4 text-yellow-600" />
                             <span className="text-xs font-bold text-yellow-800">معلومات إضافية</span>
                           </div>
                           <p className="text-sm font-medium text-slate-700 whitespace-pre-wrap leading-relaxed">
                             {emergencyProfile.additionalInfo || 'لا يوجد'}
                           </p>
                        </div>
                      )}
                      <button 
                        onClick={() => setIsEditingEmergency(true)}
                        className="w-full bg-white border-2 border-slate-200 hover:border-red-300 hover:bg-red-50 text-slate-700 hover:text-red-700 font-bold py-2.5 rounded-xl transition-colors mt-2"
                      >
                        تعديل البيانات
                      </button>
                    </>
                  )}
                </div>
             </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Smart Health Assessment Side Panel */}
      <AnimatePresence>
        {isAssessmentOpen && (
          <>
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setIsAssessmentOpen(false)}
              className="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[70]"
            />
            <motion.div
              initial={{ x: '100%', opacity: 0 }}
              animate={{ x: 0, opacity: 1 }}
              exit={{ x: '100%', opacity: 0 }}
              transition={{ type: 'spring', damping: 25, stiffness: 200 }}
              className="fixed top-0 right-0 h-full w-full sm:w-[450px] bg-white z-[80] shadow-2xl flex flex-col border-l border-slate-200"
            >
              <div className="flex items-center justify-between p-5 border-b border-slate-100 bg-indigo-50/50">
                <div className="flex items-center gap-3">
                  <div className="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600">
                    <Heart className="w-5 h-5" />
                  </div>
                  <div>
                    <h2 className="text-base font-bold text-slate-800 leading-tight">التقييم الصحي الذكي</h2>
                    <p className="text-[11px] font-medium text-slate-500">مبني على كافة سجلاتك الحالية</p>
                  </div>
                </div>
                <button 
                  onClick={() => setIsAssessmentOpen(false)}
                  className="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-200 text-slate-500 transition-colors"
                >
                  <XIcon className="w-5 h-5" />
                </button>
              </div>

              <div className="flex-grow overflow-y-auto p-6 relative">
                {isGeneratingAssessment ? (
                  <div className="flex flex-col items-center justify-center h-full text-center space-y-4">
                    <Loader2 className="w-10 h-10 text-indigo-500 animate-spin" />
                    <p className="text-sm font-bold text-slate-700 animate-pulse">يتم تحليل كافة سجلاتك واستخراج التوصيات...</p>
                  </div>
                ) : (
                  <div className="prose prose-sm prose-slate prose-headings:text-indigo-900 prose-a:text-indigo-600 w-full max-w-none text-right">
                    <Markdown>{healthAssessment || 'لم يتم العثور على التقييم.'}</Markdown>
                  </div>
                )}
              </div>
              
              {!isGeneratingAssessment && (
                <div className="p-4 border-t border-slate-100 bg-slate-50">
                   <button 
                     onClick={generateHealthAssessment}
                     className="w-full bg-white border border-slate-200 hover:border-indigo-300 hover:bg-indigo-50 text-slate-700 hover:text-indigo-700 font-bold py-2.5 rounded-xl transition-colors text-sm"
                   >
                     إعادة التقييم
                   </button>
                </div>
              )}
            </motion.div>
          </>
        )}
      </AnimatePresence>

      {/* Category Manager Modal */}
      <AnimatePresence>
        {isCategoryManagerOpen && (
          <>
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 transition-opacity"
              onClick={() => setIsCategoryManagerOpen(false)}
            />
            <motion.div
              initial={{ opacity: 0, scale: 0.95, y: 20 }}
              animate={{ opacity: 1, scale: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.95, y: 20 }}
              className="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-sm bg-white rounded-2xl shadow-2xl z-50 overflow-hidden flex flex-col max-h-[80vh]"
            >
              <div className="bg-slate-50 border-b border-slate-100 px-4 py-3 flex items-center justify-between sticky top-0 z-10">
                <div className="flex items-center gap-2">
                  <div className="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center text-indigo-600">
                    <ListChecks className="w-4 h-4" />
                  </div>
                  <div>
                    <h3 className="text-sm font-bold text-slate-800 leading-tight">إدارة التصنيفات</h3>
                    <p className="text-[10px] text-slate-500 font-medium">إضافة، تعديل، أو حذف التصنيفات المخصصة</p>
                  </div>
                </div>
                <button
                  onClick={() => setIsCategoryManagerOpen(false)}
                  className="w-8 h-8 flex items-center justify-center rounded-full text-slate-400 hover:text-slate-600 hover:bg-slate-200/50 transition-colors"
                >
                  <XIcon className="w-4 h-4" />
                </button>
              </div>
              <div className="p-4 overflow-y-auto custom-scrollbar">
                <div className="flex gap-2 mb-6">
                  <input
                    type="text"
                    id="newCategoryInput"
                    placeholder="اسم التصنيف الجديد..."
                    className="flex-grow bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-indigo-500 font-medium text-slate-800"
                    onKeyDown={(e) => {
                      if (e.key === 'Enter') {
                        const val = e.currentTarget.value.trim();
                        if (val && !DEFAULT_CATEGORIES.includes(val) && !customCategories.includes(val)) {
                          setCustomCategories([...customCategories, val]);
                          e.currentTarget.value = '';
                        }
                      }
                    }}
                  />
                  <button
                    onClick={() => {
                      const input = document.getElementById('newCategoryInput') as HTMLInputElement;
                      if (!input) return;
                      const val = input.value.trim();
                      if (val && !DEFAULT_CATEGORIES.includes(val) && !customCategories.includes(val)) {
                        setCustomCategories([...customCategories, val]);
                        input.value = '';
                      }
                    }}
                    className="bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-2 rounded-lg text-xs font-bold transition-colors flex items-center gap-1 shrink-0"
                  >
                    <Plus className="w-4 h-4" />
                    <span className="hidden sm:inline">إضافة</span>
                  </button>
                </div>
                
                <div className="space-y-2">
                  <div className="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">التصنيفات المخصصة ({customCategories.length})</div>
                  {customCategories.length === 0 ? (
                    <div className="text-center py-6 bg-slate-50 rounded-xl border border-slate-100 border-dashed text-slate-400 text-xs font-medium">
                      لم تقم بإضافة أي تصنيفات مخصصة بعد.
                    </div>
                  ) : (
                    customCategories.map((cat, idx) => (
                      <div key={idx} className="flex items-center justify-between bg-white border border-slate-200 rounded-lg p-2 shadow-sm">
                        <span className="text-xs font-bold text-slate-700 px-2">{cat}</span>
                        <div className="flex items-center gap-1">
                          <button
                            onClick={() => {
                              const newName = prompt('تعديل اسم التصنيف:', cat);
                              if (newName && newName.trim() && newName !== cat) {
                                const trimmed = newName.trim();
                                if (!DEFAULT_CATEGORIES.includes(trimmed) && !customCategories.includes(trimmed)) {
                                  setCustomCategories(customCategories.map(c => c === cat ? trimmed : c));
                                  if (categoryFilter === cat) setCategoryFilter(trimmed);
                                  setHistoryEvents(prev => prev.map(e => e.category === cat ? { ...e, category: trimmed } : e));
                                }
                              }
                            }}
                            className="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors"
                            title="تعديل"
                          >
                            <Edit2 className="w-3.5 h-3.5" />
                          </button>
                          <button
                            onClick={() => {
                              if (window.confirm(`هل أنت متأكد من حذف التصنيف '${cat}'؟ سيتم تعيين الأحداث المرتبطة به كـ 'غير محدد'.`)) {
                                setCustomCategories(customCategories.filter(c => c !== cat));
                                if (categoryFilter === cat) setCategoryFilter('الكل');
                                setHistoryEvents(prev => prev.map(e => e.category === cat ? { ...e, category: 'غير محدد' } : e));
                              }
                            }}
                            className="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors"
                            title="حذف"
                          >
                            <Trash2 className="w-3.5 h-3.5" />
                          </button>
                        </div>
                      </div>
                    ))
                  )}
                </div>
              </div>
            </motion.div>
          </>
        )}
      </AnimatePresence>

      {/* Chat Assistant */}
      {!isFocusMode && (
      <div className="fixed bottom-4 right-4 z-50 flex flex-col items-end pointer-events-none">
        <AnimatePresence>
          {isChatOpen && (
            <motion.div
              initial={{ opacity: 0, scale: 0.9, y: 20 }}
              animate={{ opacity: 1, scale: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.9, y: 20 }}
              className="bg-white rounded-2xl shadow-2xl border border-slate-200 w-[90vw] sm:w-[400px] h-[500px] flex flex-col mb-4 pointer-events-auto overflow-hidden"
            >
              {/* Chat Header */}
              <div className="bg-indigo-600 px-4 py-3 flex items-center justify-between text-white shrink-0">
                <div className="flex items-center gap-2">
                  <div className="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center">
                    <Bot className="w-5 h-5" />
                  </div>
                  <div>
                    <h3 className="text-sm font-bold leading-tight">صحتي المساعد الذكي</h3>
                    <p className="text-[10px] text-indigo-200 font-medium w-full truncate">أرشيفك الصحي ومساعدك الطبي الافتراضي</p>
                  </div>
                </div>
                <button
                  onClick={() => setIsChatOpen(false)}
                  className="p-1 hover:bg-white/20 rounded-md transition-colors"
                >
                  <XIcon className="w-5 h-5" />
                </button>
              </div>

              {/* Chat Messages */}
              <div className="flex-1 overflow-y-auto p-4 flex flex-col gap-3 custom-scrollbar bg-slate-50">
                {chatMessages.length === 0 ? (
                  <div className="flex flex-col items-center justify-center h-full text-center text-slate-400 gap-3 px-4">
                    <Bot className="w-12 h-12 opacity-20" />
                    <p className="text-xs font-medium">أهلاً بك! أنا مساعدك الذكي.<br/>اسألني وسأقوم بتسجيل الأعراض أو الأدوية وإخبارك بالإرشادات اللازمة.</p>
                  </div>
                ) : (
                  chatMessages.map((msg, idx) => (
                    <div key={idx} className={cn("flex flex-col max-w-[85%]", msg.role === 'user' ? "self-end items-end" : "self-start items-start")}>
                      <div className={cn(
                        "px-3 py-2 rounded-2xl text-sm shadow-sm",
                        msg.role === 'user' ? "bg-indigo-600 text-white rounded-br-sm" : "bg-white border border-slate-200 text-slate-700 rounded-bl-sm"
                      )}>
                        {msg.role === 'user' ? msg.text : (
                          <div className="chat-markdown prose prose-sm prose-slate rtl:prose-p:text-right rtl:prose-li:text-right max-w-none text-xs">
                             <Markdown components={{
                                p: ({node, ...props}) => <p className="mb-2 last:mb-0 leading-relaxed" {...props} />,
                                a: ({node, ...props}) => <a className="text-indigo-600 underline font-medium" target="_blank" rel="noopener noreferrer" {...props} />
                              }}>{msg.text}</Markdown>
                          </div>
                        )}
                      </div>
                      <span className="text-[9px] text-slate-400 mt-1 px-1">
                        {msg.role === 'user' ? 'أنت' : 'صحتي المساعد الذكي'}
                      </span>
                    </div>
                  ))
                )}
                {isChatLoading && (
                  <div className="flex items-center gap-2 text-slate-400 text-xs mt-2 self-start bg-white border border-slate-200 px-3 py-2 rounded-2xl rounded-bl-sm shadow-sm">
                    <Loader2 className="w-3.5 h-3.5 animate-spin" />
                    <span>جاري التفكير...</span>
                  </div>
                )}
              </div>

              {/* Chat Input */}
              <div className="p-3 bg-white border-t border-slate-100 shrink-0 pointer-events-auto">
                <form 
                  onSubmit={(e) => { e.preventDefault(); handleSendChatMessage(); }}
                  className="flex items-center gap-2 bg-slate-50 border border-slate-200 rounded-xl px-2 py-1.5 focus-within:ring-2 focus-within:ring-indigo-500 focus-within:border-transparent transition-all"
                >
                  <input
                    type="text"
                    value={chatInput}
                    onChange={(e) => setChatInput(e.target.value)}
                    placeholder="اكتب هنا ما تشعر به أو سؤالك..."
                    className="flex-1 bg-transparent border-none focus:outline-none text-xs px-2 py-1.5 text-slate-700"
                    disabled={isChatLoading}
                  />
                  <button
                    type="submit"
                    disabled={isChatLoading || !chatInput.trim()}
                    className="p-2 rounded-lg bg-indigo-600 text-white disabled:bg-slate-300 transition-colors shrink-0"
                  >
                    <Send className="w-4 h-4 rtl:rotate-180" />
                  </button>
                </form>
              </div>
            </motion.div>
          )}
        </AnimatePresence>

        <button
          onClick={() => setIsChatOpen(!isChatOpen)}
          className={cn(
            "w-14 h-14 rounded-full shadow-lg flex items-center justify-center transition-all pointer-events-auto",
            isChatOpen ? "bg-slate-800 text-white hover:bg-slate-700" : "bg-indigo-600 text-white hover:bg-indigo-700 hover:scale-105"
          )}
        >
          {isChatOpen ? <XIcon className="w-6 h-6" /> : <MessageCircle className="w-6 h-6" />}
        </button>
      </div>
      )}

      {/* Notifications Toasts */}
      <div className="fixed bottom-4 right-4 sm:right-auto sm:left-4 z-[60] flex flex-col gap-3 pointer-events-none">
        <AnimatePresence>
          {activeNotifications.map(notif => (
            <motion.div 
              key={notif.id}
              initial={{ opacity: 0, y: 50, scale: 0.9 }}
              animate={{ opacity: 1, y: 0, scale: 1 }}
              exit={{ opacity: 0, x: -50, scale: 0.9 }}
              className="bg-white rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] border border-slate-200 p-4 w-full sm:w-80 pointer-events-auto flex items-start gap-3"
            >
              <div className={cn("w-10 h-10 rounded-full flex items-center justify-center shrink-0 mt-0.5", 
                notif.type === 'appointment' ? "bg-teal-100 text-teal-600" : 
                notif.type === 'prescription' ? "bg-amber-100 text-amber-600" : 
                "bg-sky-100 text-sky-600"
              )}>
                {notif.type === 'appointment' ? <Clock className="w-5 h-5"/> : 
                 notif.type === 'prescription' ? <AlertCircle className="w-5 h-5"/> : 
                 <Pill className="w-5 h-5"/>}
              </div>
              <div className="flex-grow">
                <h4 className="font-bold text-slate-800 text-sm">{notif.title}</h4>
                <p className="text-xs text-slate-500 mt-1 leading-relaxed">{notif.message}</p>
                <div className="flex gap-2 mt-3 pt-3 border-t border-slate-100">
                  <button 
                    onClick={() => handleSnoozeNotif(notif.id, 15)} 
                    className="bg-slate-50 hover:bg-slate-100 text-slate-600 text-xs font-bold py-1.5 px-3 rounded-lg flex-grow transition-colors"
                  >
                    تأجيل 15د
                  </button>
                  <button 
                    onClick={() => handleDismissNotif(notif.id)} 
                    className="bg-indigo-50 hover:bg-indigo-100 text-indigo-700 text-xs font-bold py-1.5 px-3 rounded-lg flex-grow transition-colors"
                  >
                    حسناً
                  </button>
                </div>
              </div>
            </motion.div>
          ))}
        </AnimatePresence>
      </div>

    </div>
  );
}
