rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return false; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      match /store/{key} {
        allow read, write, list: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /events/{eventId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /appointments/{appointmentId} {
        allow read, write, list: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /vitals/{vitalId} {
        allow read, write, list: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /labRecords/{labRecordId} {
        allow read, write, list: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /medications/{medicationId} {
        allow read, write, list: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /symptoms/{symptomId} {
        allow read, write, list: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
